# ── Dream 100 environment variables ─────────────────────────────────
# Copy to .env.local for local dev. NEVER commit real values.
# In production these live in Vercel → Project → Settings → Environment Variables.

# Supabase (Project → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=            # https://xxxx.supabase.co — safe to expose to browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=       # public "anon" key — safe in browser, RLS protects data
SUPABASE_SERVICE_ROLE_KEY=           # BYPASSES RLS. Server-only (webhook/cron). Guard with your life.

# Anthropic (console.anthropic.com → API keys)
ANTHROPIC_API_KEY=

# Zoho CRM (api-console.zoho.com Self Client)
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=                  # long-lived; used to mint short-lived access tokens
ZOHO_ACCOUNTS_URL=https://accounts.zoho.com  # this org's DC is .com — confirmed via crm.zoho.com URL 2026-07-09
ZOHO_API_DOMAIN=https://www.zohoapis.com
ZOHO_WEBHOOK_SECRET=                 # random string; Zoho workflow sends it, our webhook verifies it

# Vercel cron protection (Vercel sends "Authorization: Bearer <this>" to cron routes)
CRON_SECRET=

# Auth method: Supabase email+password (decided 2026-07-08) — no external
# OAuth provider, so no extra credentials needed here.
